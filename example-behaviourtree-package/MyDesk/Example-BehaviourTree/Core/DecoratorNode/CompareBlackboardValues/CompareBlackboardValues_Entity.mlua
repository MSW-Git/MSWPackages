@BTNode
script CompareBlackboardValues_Entity extends DecoratorNode

	property string LeftKey = ""

	property string RightKey = ""

	property integer Operator = 0

	method any OnBehave(number delta)
		local leftValue = self.ParentAI.BlackBoard:GetEntity(self.LeftKey)
		local rightValue = self.ParentAI.BlackBoard:GetEntity(self.RightKey)
		if _Comparator:Compare(_ValueType.Entity, self.Operator, leftValue, rightValue) then
			return self:ChildBehave(delta)
		end
		
		return BehaviourTreeStatus.Failure
	end

end