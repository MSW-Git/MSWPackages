@BTNode
script BlackboardCondition_Number extends DecoratorNode

	property string Key = ""

	property integer Operator = 0

	property number CompareValue = 0

	method any OnBehave(number delta)
		if _UtilLogic:IsNilorEmptyString(self.Key) then
			return BehaviourTreeStatus.Failure
		end
		
		local compareValue = self.ParentAI.BlackBoard:GetNumber(self.Key)
		if _Comparator:Compare(_ValueType.Number, self.Operator, compareValue, self.CompareValue) then
			return self:ChildBehave(delta)
		end
		
		return BehaviourTreeStatus.Failure
	end

end