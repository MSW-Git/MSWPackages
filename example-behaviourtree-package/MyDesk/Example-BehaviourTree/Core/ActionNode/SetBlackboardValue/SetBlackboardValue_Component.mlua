@BTNode
script SetBlackboardValue_Component extends ActionNode

	property string Key = ""

	property Component Value = nil

	method any OnBehave(number delta)
		local aiComponent = self.ParentAI
		if aiComponent == nil then
			return BehaviourTreeStatus.Failure
		end
		
		aiComponent.BlackBoard:SetComponent(self.Key, self.Value)
		return BehaviourTreeStatus.Success
	end

end