@BTNode
script SetBlackboardValue_Vector3 extends ActionNode

	property string Key = ""

	property Vector3 Value = Vector3(0.000, 0.000, 0.000)

	method any OnBehave(number delta)
		local aiComponent = self.ParentAI
		if aiComponent == nil then
			return BehaviourTreeStatus.Failure
		end
		
		aiComponent.BlackBoard:SetVector3(self.Key, self.Value)
		return BehaviourTreeStatus.Success
	end

end