@BTNode
script SetBlackboardValue_Bool extends ActionNode

	property string Key = ""

	property boolean Value = false

	method any OnBehave(number delta)
		local aiComponent = self.ParentAI
		if aiComponent == nil then
			return BehaviourTreeStatus.Failure
		end
		
		aiComponent.BlackBoard:SetBool(self.Key, self.Value)
		return BehaviourTreeStatus.Success
	end

end