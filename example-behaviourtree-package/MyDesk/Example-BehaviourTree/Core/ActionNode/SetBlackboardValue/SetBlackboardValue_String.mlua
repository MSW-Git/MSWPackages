@BTNode
script SetBlackboardValue_String extends ActionNode

	property string Key = ""

	property string Value = ""

	method any OnBehave(number delta)
		local aiComponent = self.ParentAI
		if aiComponent == nil then
			return BehaviourTreeStatus.Failure
		end
		
		aiComponent.BlackBoard:SetString(self.Key, self.Value)
		return BehaviourTreeStatus.Success
	end

end