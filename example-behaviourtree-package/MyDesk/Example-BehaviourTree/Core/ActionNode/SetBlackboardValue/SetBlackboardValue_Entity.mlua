@BTNode
script SetBlackboardValue_Entity extends ActionNode

	property string Key = ""

	property Entity Value = nil

	method any OnBehave(number delta)
		local aiComponent = self.ParentAI
		if aiComponent == nil then
			return BehaviourTreeStatus.Failure
		end
		
		aiComponent.BlackBoard:SetEntity(self.Key, self.Value)
		return BehaviourTreeStatus.Success
	end

end