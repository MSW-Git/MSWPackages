@BTNode
script SetBlackboardValue_Color extends ActionNode

	property string Key = ""

	property Color Value = Color(1.000, 1.000, 1.000, 1.000)

	method any OnBehave(number delta)
		local aiComponent = self.ParentAI
		if aiComponent == nil then
			return BehaviourTreeStatus.Failure
		end
		
		aiComponent.BlackBoard:SetColor(self.Key, self.Value)
		return BehaviourTreeStatus.Success
	end

end